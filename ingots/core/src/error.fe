use ingot::abi::{Abi, AbiSize, Encode}

/// Trait implemented by `#[error]` structs for Solidity-compatible custom errors.
///
/// Each `#[error]` struct desugars to an implementation of this trait,
/// pairing a 4-byte selector with ABI encoding capability.
/// The selector is computed at compile time from the struct name and
/// field types, matching the Solidity custom error ABI.
pub trait ErrorVariant<A: Abi>: Encode<A> + AbiSize {
    const SELECTOR: A::Selector
}
